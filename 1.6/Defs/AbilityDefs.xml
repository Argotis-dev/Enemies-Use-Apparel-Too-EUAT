    <AbilityDef>
        <defName>EUAT_LaunchDeadlifeCapsule</defName>
        <label>launch deadlife capsule</label>
        <description>Launch a Deadlife Capsule. Destroyed on use.</description>
        <iconPath>UI/Abilities/ReleaseDeadlifeDust</iconPath>
        <aiCanUse>true</aiCanUse>
        <showWhenDrafted>false</showWhenDrafted>
        <!--<ai_SearchAOEForTargets>true</ai_SearchAOEForTargets>
        <statBases>
          <Ability_EffectRadius>23.9</Ability_EffectRadius>
        </statBases>-->
        <!--<displayGizmoWhileUndrafted>true</displayGizmoWhileUndrafted>
        <disableGizmoWhileUndrafted>false</disableGizmoWhileUndrafted>-->
        <statBases>
          <Ability_Duration>20</Ability_Duration>
        </statBases>
        <verbProperties>
          <verbClass>Verb_CastAbility</verbClass>
          <range>23.9</range>
          <warmupTime>1.5</warmupTime>
          <forcedMissRadius>0.1</forcedMissRadius>
          <soundCast>ThrowGrenade</soundCast>
          <targetParams>
              <canTargetPawns>false</canTargetPawns>
              <canTargetCorpses>true</canTargetCorpses>
              <canTargetBuildings>false</canTargetBuildings>
              <canTargetLocations>true</canTargetLocations>
          </targetParams>
          <rangedFireRulepack>Combat_RangedFire_Thrown</rangedFireRulepack>
        </verbProperties>
        <comps>
        <!--shoot a blank grendae equivalant for visuals, then release deadlife gas at location-->
        <li Class="CompProperties_AbilityLaunchProjectile">
            <projectileDef>Grenade_Deadlife</projectileDef>
        </li>
        <li Class = "EnemiesUseApparelToo.CompProperties_AbilityEffectMarkDeadlifeGasAtDest">
          <gasType>DeadlifeDust</gasType>
          <cellsToFill>20</cellsToFill>
        </li>
        <li Class="EnemiesUseApparelToo.CompProperties_AbilityChargesApparel">
        </li>
        </comps>
    </AbilityDef>

