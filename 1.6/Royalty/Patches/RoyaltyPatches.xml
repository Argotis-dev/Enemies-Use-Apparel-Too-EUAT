<?xml version="1.0" encoding="utf-8" ?>
<Patch>
    <!-- Needs Royalty -->
    <!-- If the harmony patch is enabled then adding these abilities is unnecessary-->
    <Operation Class="EnemiesUseApparelToo.EUAT_PatchIfHarmonyEnabled">
    <invert>true</invert>
        <operations>   
        <!-- Add Grenadelaunch Ability to Grenadier Armor -->
        <li Class="PatchOperationConditional">
            <xpath>Defs/ThingDef[defName="Apparel_ArmorMarineGrenadier"]/apparel/abilities</xpath>
            <nomatch Class="PatchOperationAdd">
            <xpath>Defs/ThingDef[defName="Apparel_ArmorMarineGrenadier"]/apparel</xpath>
                <value>
                    <abilities /> 
                </value>
            </nomatch>
        </li>  
        <li Class="PatchOperationAdd">
            <xpath>Defs/ThingDef[defName="Apparel_ArmorMarineGrenadier"]/apparel/abilities</xpath>
            <value>
                <li>EUAT_LaunchFragGrenadeApparel</li>
            </value>
        </li>
        <!-- Add Launch Incendiary Ability to Pheonix Armor -->
        <li Class="PatchOperationConditional">
            <xpath>Defs/ThingDef[defName="Apparel_ArmorCataphractPhoenix"]/apparel/abilities</xpath>
            <nomatch Class="PatchOperationAdd">
            <xpath>Defs/ThingDef[defName="Apparel_ArmorCataphractPhoenix"]/apparel</xpath>
                <value>
                    <abilities /> 
                </value>
            </nomatch>
        </li>    
        <li Class="PatchOperationAdd">
            <xpath>Defs/ThingDef[defName="Apparel_ArmorCataphractPhoenix"]/apparel/abilities</xpath>
            <value>
                <li>EUAT_LaunchIncendiaryPheonixArmor</li>
            </value>
        </li>
        </operations>
    </Operation>  
    <!-- Add Spacer Military Tag to Grenadier Armor -->
    <Operation Class="PatchOperationConditional">
        <xpath>Defs/ThingDef[defName="Apparel_ArmorMarineGrenadier"]/apparel/tags</xpath>
        <nomatch Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Apparel_ArmorMarineGrenadier"]/apparel</xpath>
            <value>
                <tags /> 
            </value>
        </nomatch>
    </Operation>  
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Apparel_ArmorMarineGrenadier"]/apparel/tags</xpath>
        <value>          
           <li>SpacerMilitary</li>
           <li>EUAT_OrbitalPowerArmor</li>
        </value>
    </Operation>
    <!-- Add Spacer Military Tag to Pheonix Armor -->
    <Operation Class="PatchOperationConditional">
        <xpath>Defs/ThingDef[defName="Apparel_ArmorCataphractPhoenix"]/apparel/tags</xpath>
        <nomatch Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Apparel_ArmorCataphractPhoenix"]/apparel</xpath>
            <value>
                <tags />
            </value>
        </nomatch>
    </Operation>    
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Apparel_ArmorCataphractPhoenix"]/apparel/tags</xpath>
        <value>
            <li>SpacerMilitary</li>
            <li>EUAT_CataphractVariant</li>
        </value>
    </Operation>
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/PawnKindDef[defName="Empire_Fighter_Cataphract"]/specificApparelRequirements</xpath>
        <value>
            <li>
                <bodyPartGroup>Torso</bodyPartGroup>
                <apparelLayer>Middle</apparelLayer>
                <color>(250, 250, 250)</color>
                <alternateTagChoices>
                <li>
                    <tag>EUAT_CataphractVariant</tag>
                    <chance>0.5</chance>
                </li>
                </alternateTagChoices>
            </li>
        </value>
    </Operation>
    <!-- Add Jet Jump Ability to Locust Armor -->
    <Operation Class="PatchOperationConditional">
        <xpath>Defs/ThingDef[defName="Apparel_ArmorLocust"]/apparel/abilities</xpath>
        <nomatch Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Apparel_ArmorLocust"]/apparel</xpath>
            <value>
                <abilities /> 
            </value>
        </nomatch>
    </Operation>    
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Apparel_ArmorLocust"]/apparel/abilities</xpath>
        <value>
            <li>EUAT_JetJump</li>
        </value>
    </Operation>
    <!-- Add Spacer Military Tag to Locust Armor-->
    <Operation Class="PatchOperationConditional">
        <xpath>Defs/ThingDef[defName="Apparel_ArmorLocust"]/apparel/tags</xpath>
        <nomatch Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Apparel_ArmorLocust"]/apparel</xpath>
            <value>
                <tags /> 
            </value>
        </nomatch>
    </Operation>    
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Apparel_ArmorLocust"]/apparel/tags</xpath>
        <value>
            <li>SpacerMilitary</li>
            <li>EUAT_LocustVariant</li>
            <li>EUAT_OrbitalPowerArmor</li>
        </value>
    </Operation>
    <Operation Class="PatchOperationConditional">
        <xpath>Defs/PawnKindDef[defName="Empire_Fighter_Champion"]/specificApparelRequirements</xpath>
        <nomatch Class="PatchOperationAdd">
        <xpath>Defs/PawnKindDef[defName="Empire_Fighter_Champion"]</xpath>
            <value>
                <specificApparelRequirements />
            </value>
        </nomatch>
    </Operation>    
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/PawnKindDef[defName="Empire_Fighter_Champion"]/specificApparelRequirements</xpath>
        <value>
            <li>
                <bodyPartGroup>Torso</bodyPartGroup>
                <apparelLayer>Middle</apparelLayer>
                <color>(250, 250, 250)</color>
                <alternateTagChoices>
                <li>
                    <tag>EUAT_LocustVariant</tag>
                    <chance>0.50</chance>
                </li>
                </alternateTagChoices>
            </li>
        </value>
    </Operation>
    <!-- Add Jet Jump Ability to Jump Packs-->
    <Operation Class="PatchOperationConditional">
        <xpath>Defs/ThingDef[defName="Apparel_PackJump"]/apparel/abilities</xpath>
        <nomatch Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Apparel_PackJump"]/apparel</xpath>
            <value>
                <abilities /> 
            </value>
        </nomatch>
    </Operation>    
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Apparel_PackJump"]/apparel/abilities</xpath>
        <value>
            <li>EUAT_JetJump</li>
        </value>
    </Operation>
    <!-- Add Defense Pop Tag to Jump Pack-->
    <Operation Class="PatchOperationConditional">
        <xpath>Defs/ThingDef[defName="Apparel_PackJump"]/apparel/tags</xpath>
        <nomatch Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Apparel_PackJump"]/apparel</xpath>
            <value>
                <tags /> 
            </value>
        </nomatch>
    </Operation>    
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Apparel_PackJump"]/apparel/tags</xpath>
        <value>
            <li>BeltDefensePop</li>
        </value>
    </Operation>
    <Operation Class="PatchOperationConditional">
        <xpath>Defs/ThingDef[defName="Apparel_PackJump"]/generateAllowChance</xpath>
        <nomatch Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Apparel_PackJump"]</xpath>
            <value>
                <generateAllowChance>0.15</generateAllowChance>
            </value>
        </nomatch>
    </Operation> 
    <!--<Operation Class="PatchOperationInsert">
        <xpath>Defs/ThinkTreeDef[defName = "HumanlikeConstant"]/thinkRoot[@Class = "ThinkNode_Priority"]/subNodes/li[@Class="ThinkNode_ConditionalCanDoConstantThinkTreeJobNow"]/subNodes/li[@Class="JobGiver_FleePotentialExplosion"]</xpath>
        <value>
            <li Class="ThinkNode_Subtree">
                <treeDef>EUAT_Flee_Explosion_Jump</treeDef>
            </li>
        </value>
    </Operation>-->
</Patch>