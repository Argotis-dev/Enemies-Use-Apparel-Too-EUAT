<?xml version="1.0" encoding="utf-8" ?>
<Patch>
    <!-- Needs Odyssey -->
    <!-- If the harmony patch is enabled then adding this ability is unnecessary-->
    <Operation Class="EnemiesUseApparelToo.EUAT_PatchIfHarmonyEnabled">
    <invertHarmony>true</invertHarmony>
        <operations>
        <li Class="PatchOperationConditional">
            <xpath>Defs/ThingDef[defName="Apparel_PackHunter"]/apparel/abilities</xpath>
            <nomatch Class="PatchOperationAdd">
            <xpath>Defs/ThingDef[defName="Apparel_PackHunter"]/apparel</xpath>
                <value>
                    <abilities /> 
                </value>
            </nomatch>
        </li>    
        <li Class="PatchOperationAdd">
            <xpath>Defs/ThingDef[defName="Apparel_PackHunter"]/apparel/abilities</xpath>
            <value>
                <li>EUAT_DeployHunterDrone</li>
            </value>
        </li>
        </operations>
    </Operation>  
    <!--Add Defense Pop Tag to Hunter Drone Pack-->
    <Operation Class="PatchOperationConditional">
        <xpath>Defs/ThingDef[defName="Apparel_PackHunter"]/apparel/tags</xpath>
        <nomatch Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Apparel_PackHunter"]/apparel</xpath>
            <value>
                <tags /> 
            </value>
        </nomatch>
    </Operation>    
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Apparel_PackHunter"]/apparel/tags</xpath>
        <value>
            <li>BeltDefensePop</li>
        </value>
    </Operation>
    <Operation Class="PatchOperationConditional">
        <xpath>Defs/ThingDef[defName="Apparel_PackHunter"]/generateAllowChance</xpath>
        <nomatch Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Apparel_PackHunter"]</xpath>
            <value>
                <generateAllowChance>0.15</generateAllowChance>
            </value>
        </nomatch>
    </Operation> 
    <!-- Add Grenadier armor and Locust armor to Elite Spacers -->
    <Operation Class="PatchOperationConditional">
        <xpath>Defs/PawnKindDef[@Name="TradersGuildEliteBase"]/specificApparelRequirements</xpath>
        <nomatch Class="PatchOperationAdd">
        <xpath>Defs/PawnKindDef[@Name="TradersGuildEliteBase"]</xpath>
            <value>
                <specificApparelRequirements /> 
            </value>
        </nomatch>
    </Operation>  
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/PawnKindDef[@Name="TradersGuildEliteBase"]/specificApparelRequirements</xpath>
        <value>
            <li>
                <bodyPartGroup>Torso</bodyPartGroup>
                <apparelLayer>Middle</apparelLayer>
                <color>(250, 250, 250)</color>
                <alternateTagChoices>
                <li>
                    <tag>EUAT_OrbitalPowerArmor</tag>
                    <chance>0.50</chance>
                </li>
                </alternateTagChoices>
            </li>
        </value>
    </Operation>
    <!-- Adds Locust armor to spacer slashers -->
    <Operation Class="PatchOperationConditional">
        <xpath>Defs/PawnKindDef[@Name="TradersGuildSlasherBase"]/specificApparelRequirements</xpath>
        <nomatch Class="PatchOperationAdd">
        <xpath>Defs/PawnKindDef[@Name="TradersGuildSlasherBase"]</xpath>
            <value>
                <specificApparelRequirements /> 
            </value>
        </nomatch>
    </Operation>  
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/PawnKindDef[@Name="TradersGuildSlasherBase"]/specificApparelRequirements</xpath>
        <value>
            <li>
                <bodyPartGroup>Torso</bodyPartGroup>
                <apparelLayer>Middle</apparelLayer>
                <color>(250, 250, 250)</color>
                <alternateTagChoices>
                <li>
                    <tag>EUAT_LocustVariant</tag>
                    <chance>0.10</chance>
                </li>
                </alternateTagChoices>
            </li>
        </value>
    </Operation>
</Patch>    