<?xml version="1.0" encoding="utf-8" ?>
<Patch>
    <!-- Needs Royalty -->
    <!-- Add Grenadelaunch Ability to Grenadier Armor -->
    <Operation Class="PatchOperationConditional">
        <xpath>Defs/ThingDef[defName="Apparel_ArmorMarineGrenadier"]/apparel/abilities</xpath>
        <nomatch Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Apparel_ArmorMarineGrenadier"]/apparel</xpath>
            <value>
                <abilities /> 
            </value>
        </nomatch>
    </Operation>  
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Apparel_ArmorMarineGrenadier"]/apparel/abilities</xpath>
        <value>
            <li>EUAT_LaunchFragGrenadeApparel</li>
        </value>
    </Operation>
    <Operation Class="PatchOperationRemove">
        <xpath>Defs/ThingDef[defName="Apparel_ArmorMarineGrenadier"]/verbs</xpath>
    </Operation>
    <!-- Add Spacer Military Tag to Grenadier Armor -->
    <Operation Class="PatchOperationConditional">
        <xpath>Defs/ThingDef[defName="Apparel_ArmorMarineGrenadier"]/apparel/tags</xpath>
        <nomatch Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Apparel_ArmorMarineGrenadier"]/apparel</xpath>
            <value>
                <tags /> 
            </value>
        </nomatch>
    </Operation>  
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Apparel_ArmorMarineGrenadier"]/apparel/tags</xpath>
        <value>          
           <li>SpacerMilitary</li>
           <li>OrbitalPowerArmor</li>
        </value>
    </Operation>
    <!-- Add Launch Incendiary Ability to Pheonix Armor -->
    <Operation Class="PatchOperationConditional">
        <xpath>Defs/ThingDef[defName="Apparel_ArmorCataphractPhoenix"]/apparel/abilities</xpath>
        <nomatch Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Apparel_ArmorCataphractPhoenix"]/apparel</xpath>
            <value>
                <abilities /> 
            </value>
        </nomatch>
    </Operation>    
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Apparel_ArmorCataphractPhoenix"]/apparel/abilities</xpath>
        <value>
            <li>EUAT_LaunchIncendiaryPheonixArmor</li>
        </value>
    </Operation>
    <Operation Class="PatchOperationRemove">
        <xpath>Defs/ThingDef[defName="Apparel_ArmorCataphractPhoenix"]/verbs</xpath>
    </Operation>
    <!-- Add Spacer Military Tag to Pheonix Armor -->
    <Operation Class="PatchOperationConditional">
        <xpath>Defs/ThingDef[defName="Apparel_ArmorCataphractPhoenix"]/apparel/tags</xpath>
        <nomatch Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Apparel_ArmorCataphractPhoenix"]/apparel</xpath>
            <value>
                <tags />
            </value>
        </nomatch>
    </Operation>    
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Apparel_ArmorCataphractPhoenix"]/apparel/tags</xpath>
        <value>
            <li>SpacerMilitary</li>
            <li>CataphractVariant</li>
        </value>
    </Operation>
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/PawnKindDef[defName="Empire_Fighter_Cataphract"]/specificApparelRequirements</xpath>
        <value>
            <li>
                <bodyPartGroup>Torso</bodyPartGroup>
                <apparelLayer>Middle</apparelLayer>
                <alternateTagChoices>
                <li>
                    <tag>CataphractVariant</tag>
                    <chance>0.5</chance>
                </li>
                </alternateTagChoices>
            </li>
        </value>
    </Operation>
    <!-- Add Jet Jump Ability to Locust Armor -->
    <Operation Class="PatchOperationConditional">
        <xpath>Defs/ThingDef[defName="Apparel_ArmorLocust"]/apparel/abilities</xpath>
        <nomatch Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Apparel_ArmorLocust"]/apparel</xpath>
            <value>
                <abilities /> 
            </value>
        </nomatch>
    </Operation>    
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Apparel_ArmorLocust"]/apparel/abilities</xpath>
        <value>
            <li>EUAT_JetJump</li>
        </value>
    </Operation>
    <Operation Class="PatchOperationRemove">
        <xpath>Defs/ThingDef[defName="Apparel_ArmorLocust"]/verbs</xpath>
    </Operation>
    <!-- Add Spacer Military Tag to Locust Armor-->
    <Operation Class="PatchOperationConditional">
        <xpath>Defs/ThingDef[defName="Apparel_ArmorLocust"]/apparel/tags</xpath>
        <nomatch Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Apparel_ArmorLocust"]/apparel</xpath>
            <value>
                <tags /> 
            </value>
        </nomatch>
    </Operation>    
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Apparel_ArmorLocust"]/apparel/tags</xpath>
        <value>
            <li>SpacerMilitary</li>
            <li>LocustVariant</li>
            <li>OrbitalPowerArmor</li>
        </value>
    </Operation>
    <Operation Class="PatchOperationConditional">
        <xpath>Defs/ThingDef[defName="Apparel_PackJump"]/apparel/abilities</xpath>
        <nomatch Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Apparel_PackJump"]/apparel</xpath>
            <value>
                <abilities /> 
            </value>
        </nomatch>
    </Operation>    
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Apparel_PackJump"]/apparel/abilities</xpath>
        <value>
            <li>EUAT_JetJump</li>
        </value>
    </Operation>
    <!-- Add Defense Pop Tag to Jump Pack-->
    <Operation Class="PatchOperationConditional">
        <xpath>Defs/ThingDef[defName="Apparel_PackJump"]/apparel/tags</xpath>
        <nomatch Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Apparel_PackJump"]/apparel</xpath>
            <value>
                <tags /> 
            </value>
        </nomatch>
    </Operation>    
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Apparel_PackJump"]/apparel/tags</xpath>
        <value>
            <li>BeltDefensePop</li>
        </value>
    </Operation>
    <Operation Class="PatchOperationConditional">
        <xpath>Defs/ThingDef[defName="Apparel_PackJump"]/generateAllowChance</xpath>
        <nomatch Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Apparel_PackJump"]</xpath>
            <value>
                <generateAllowChance>0.15</generateAllowChance>
            </value>
        </nomatch>
    </Operation> 
    <Operation Class="PatchOperationRemove">
        <xpath>Defs/ThingDef[defName="Apparel_PackJump"]/verbs</xpath>
    </Operation> 
    <Operation Class="PatchOperationInsert">
        <xpath>Defs/ThinkTreeDef[defName = "HumanlikeConstant"]/thinkRoot[@Class = "ThinkNode_Priority"]/subNodes/li[@Class="ThinkNode_ConditionalCanDoConstantThinkTreeJobNow"]/subNodes/li[@Class="JobGiver_ConfigurableHostilityResponse"]</xpath>
        <value>
            <li Class="ThinkNode_Subtree">
                <treeDef>EUAT_Abilities_Jump</treeDef>
            </li>
        </value>
    </Operation>
    <Operation Class="PatchOperationInsert">
        <xpath>Defs/ThinkTreeDef[defName = "Humanlike"]/thinkRoot[@Class = "ThinkNode_Priority"]/subNodes/li[@Class="JobGiver_ReactToCloseMeleeThreat"]</xpath>
        <value>
            <li Class="ThinkNode_Subtree">
                <treeDef>EUAT_Abilities_EscapeJump</treeDef>
            </li>
        </value>
    </Operation>
</Patch>